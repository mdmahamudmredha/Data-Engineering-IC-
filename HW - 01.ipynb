# ============================================
# TASK 1: Variables & Data Types
# ============================================
# Create variables for a data pipeline run

pipeline_name = "user_sync_pipeline"   # string: name it "user_sync_pipeline"
source_system = "crm_database"         # string: "crm_database"
total_records = 25000                  # integer: 25000
error_count = 178                      # integer: 178
processing_time = 45.7                 # float: 45.7 (seconds)
is_successful = True                   # boolean: True

# Print each variable and its type
# Example: print(f"{pipeline_name} -> {type(pipeline_name)}")

print(f"{pipeline_name} -> {type(pipeline_name)}")
print(f"{source_system} -> {type(source_system)}")
print(f"{total_records} -> {type(total_records)}")
print(f"{error_count} -> {type(error_count)}")
print(f"{processing_time} -> {type(processing_time)}")
print(f"{is_successful} -> {type(is_successful)}")



# ============================================
# TASK 2: Arithmetic Operations
# ============================================
# Using the variables from Task 1, calculate:

success_count = total_records - error_count              # total_records minus error_count
success_rate = success_count / total_records * 100       # success_count divided by total_records, times 100
error_rate = error_count / total_records * 100           # error_count divided by total_records, times 100
records_per_second = total_records / processing_time     # total_records divided by processing_time

print(f"Success count: {success_count}")
print(f"Success rate: {success_rate:.2f}%")
print(f"Error rate: {error_rate:.2f}%")
print(f"Records/sec: {records_per_second:.1f}")



# ============================================
# TASK 3: String Operations
# ============================================
# Given this messy data from a CSV file:

raw_name = "   rahim UDDIN   "
raw_email = "RAHIM@GMAIL.COM"
raw_city = "dhaka"

# Clean them up:
clean_name = raw_name.strip().title()    # strip whitespace, then title case -> "Rahim Uddin"
clean_email = raw_email.lower()          # lowercase -> "rahim@gmail.com"
clean_city = raw_city.capitalize()       # capitalize -> "Dhaka"

print(f"Name: {clean_name}")
print(f"Email: {clean_email}")
print(f"City: {clean_city}")

# Build a formatted summary string using f-string
summary = f"{clean_name} ({clean_email}) from {clean_city}"   # "Rahim Uddin (rahim@gmail.com) from Dhaka"
print(summary)



# ============================================
# TASK 4: Type Conversion
# ============================================
# This data came from a CSV file — everything is a string!

str_price = "1250.75"
str_quantity = "8"
str_discount = "15"
str_in_stock = "True"

# Convert to proper types and calculate
price = float(str_price)          # convert to float
quantity = int(str_quantity)      # convert to int
discount = int(str_discount)      # convert to int

subtotal = price * quantity                       # price * quantity
discount_amount = subtotal * discount / 100       # subtotal * discount / 100
final_total = subtotal - discount_amount          # subtotal - discount_amount

print(f"Subtotal: {subtotal:.2f} BDT")
print(f"Discount ({discount}%): -{discount_amount:.2f} BDT")
print(f"Final Total: {final_total:.2f} BDT")



# ============================================
# TASK 5: Comparisons & Booleans
# ============================================
# A data pipeline has these metrics:

rows_loaded = 9500
rows_expected = 10000
null_percentage = 3.2
max_allowed_nulls = 5.0
run_time_minutes = 12
max_run_time = 15

# Write boolean expressions:
data_complete = rows_loaded >= rows_expected                          # is rows_loaded >= rows_expected?
data_clean = null_percentage <= max_allowed_nulls                     # is null_percentage <= max_allowed_nulls?
within_time = run_time_minutes <= max_run_time                        # is run_time_minutes <= max_run_time?
all_checks_passed = data_complete and data_clean and within_time      # are ALL three True? (use 'and')
any_issue = not all_checks_passed                                     # did ANY check fail? (hint: not all_checks_passed)

print(f"Data complete: {data_complete}")
print(f"Data clean: {data_clean}")
print(f"Within time: {within_time}")
print(f"All passed: {all_checks_passed}")
print(f"Any issue: {any_issue}")



# ============================================
# TASK 6: Conditionals (if/elif/else)
# ============================================
# Write a grading system for pipeline health

pipeline_score = 87   # try changing this to test all branches

# Rules:
#   90-100 -> "EXCELLENT" (green)
#   70-89  -> "GOOD" (yellow)
#   50-69  -> "WARNING" (orange)
#   below 50 -> "CRITICAL" (red)

if pipeline_score >= 90:
    grade = "EXCELLENT"
    color = "green"
elif pipeline_score >= 70:
    grade = "GOOD"
    color = "yellow"
elif pipeline_score >= 50:
    grade = "WARNING"
    color = "orange"
else:
    grade = "CRITICAL"
    color = "red"

print(f"Pipeline Score: {pipeline_score} -> {grade} ({color})")



# ============================================
# TASK 7: For Loops
# ============================================
# Given a list of database tables and their row counts:

tables = ["customers", "orders", "products", "reviews", "inventory"]
row_counts = [15000, 42000, 3500, 28000, 7200]

# Task 7a: Print each table name in UPPERCASE
for table in tables:
    print(table.upper())

print("---")

# Task 7b: Print each table with its row count
# Hint: use range(len(tables)) or zip(tables, row_counts)
for i in range(len(tables)):
    print(f"Table: {tables[i]} -> {row_counts[i]} rows")

print("---")

# Task 7c: Find the total number of rows across all tables
total = 0
for count in row_counts:
    total += count              # add count to total

print(f"Total rows across all tables: {total}")



# ============================================
# TASK 8: While Loop
# ============================================
# Simulate a data sync that processes 1000 records per batch

remaining = 7500
batch_size = 1000
batch_number = 0

while remaining > 0:           # keep going while remaining > 0
    batch_number += 1
    if remaining >= batch_size:
        processed = batch_size
    else:
        processed = remaining
    remaining = remaining - processed  # subtract processed from remaining
    print(f"Batch {batch_number}: processed {processed}, remaining: {remaining}")

print(f"Done! Processed in {batch_number} batches")



